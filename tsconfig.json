{
  "compilerOptions": {
    "module": "commonjs",
    "target": "esnext",
    "sourceMap": false,
    "allowJs": false,
    "jsx": "react",
    "moduleResolution": "node",
    "rootDir": "src",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitAny": true,
    "strict": true,
    "ignoreDeprecations": "5.0",
    "suppressImplicitAnyIndexErrors": true,
    "noUnusedLocals": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "lib": [
      "es2015",
      "es2016",
      "dom"
    ],
    "declaration": true
  },
  "include": [
    "src/**/*"
, "src/hackaton"  ],
  "exclude": [
    "node_modules/**/*",
    "src/**/*.test.tsx",
    "src/**/*Story.tsx"
  ]
}